generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  clerkId         String?  @unique
  name            String?
  pincode         String?
  isBusinessUser  Boolean  @default(false)
  walletBalance   Float    @default(0)
  exchangePref    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  watchlist     Watchlist[]
  purchases     ProtectedPurchase[]
  notifications Notification[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  brand          String
  category       String
  image          String
  description    String
  specifications String?
  
  decisionType     String?
  decisionConf     Int?
  decisionReason   String?
  decisionMove     String?
  decisionWindow   String?
  
  fingerprintHash  String?  @unique
  verificationState String   @default("VERIFIED")
  confidenceScore  Float?
  driftAlert       Boolean  @default(false)
  
  parentProductId  String?
  parentProduct    Product?  @relation("ProductVariants", fields: [parentProductId], references: [id], onDelete: SetNull)
  variants         Product[]  @relation("ProductVariants")
  
  successorId      String?   @unique
  successor        Product?   @relation("ProductGenerations", fields: [successorId], references: [id])
  predecessor      Product?   @relation("ProductGenerations")
  
  trend            String?
  lowestPrice      Int?
  highestPrice     Int?
  averagePrice     Int?
  currentBestPrice Int
  currentBestPlatform String
  lastCalculatedAt    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  platforms         Platform[]
  oracleSnapshots  OracleSnapshot[]
  watchlistedBy     Watchlist[]
  protectedPurchases ProtectedPurchase[]
}

model Platform {
  id             String  @id @default(cuid())
  platformId     String
  externalId     String? // Marketplace PID (Product ID)
  listingId      String? // Marketplace LID (Listing ID)
  name           String
  logo           String
  price          Int
  originalPrice  Int
  effectivePrice Int
  url            String
  inStock        Boolean @default(true)
  sellerName     String?
  sellerScore    Float?  @default(0)
  sellerRating   Float?  @default(0)
  variantInfo    String? // JSON string: { color, storage, etc }
  bankOffers     String?
  lastVerifiedAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, platformId])
}

model OracleSnapshot {
  id             String   @id @default(cuid())
  timestamp      DateTime @default(now())
  date           String   // Keep for UI compatibility (YYYY-MM-DD)
  price          Int
  originalPrice  Int?
  platform       String
  sellerName     String?
  stockStatus    String?
  imageHash      String?
  rating         Float?
  reviewCount    Int?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, date])
}

model Watchlist {
  id        String   @id @default(cuid())
  targetPrice Int?
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model ProtectedPurchase {
  id             String   @id @default(cuid())
  purchasePrice  Float
  purchaseDate   DateTime @default(now())
  platformId     String
  shieldStatus   String   @default("active") // active, claimed, expired
  savingsRecovered Float  @default(0)
  createdAt      DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, shieldStatus])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // price_drop, shield_success, info
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
